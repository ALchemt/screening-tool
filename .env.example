# OpenRouter — единый шлюз для всех LLM (agent + judge + embeddings)
OPENROUTER_API_KEY=sk-or-v1-...

# Модели (можно переопределить)
AGENT_MODEL=openai/gpt-4o-mini
JUDGE_MODEL=anthropic/claude-sonnet-4.5
EMBED_MODEL=openai/text-embedding-3-small
RESPONDENT_MODEL=openai/gpt-4o-mini

# Langfuse — self-hosted на VPS Андрея (см. infra/langfuse-compose.yml)
LANGFUSE_HOST=https://langfuse.example.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000

# Persistent state (LangGraph SqliteSaver)
CHECKPOINT_DB=./data/checkpoints.sqlite

# ChromaDB persistent dir (override for HF Spaces -> /tmp/chroma)
CHROMA_DIR=./data/chroma
